{
  "name": "astara-bench",
  "version": "0.1.0",
  "description": "Godot domain benchmark suite for testing Studios framework effectiveness in real development environments",
  "type": "module",
  "bin": {
    "astara-bench": "./bin/bench.js"
  },
  "scripts": {
    "build": "bun build ./src/cli.ts --outdir ./dist --target bun",
    "bench": "bun run src/cli.ts",
    "test": "bun test tests/",
    "test:unit": "bun test tests/unit/",
    "test:structural": "bun test tests/structural/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opencode-ai/sdk": "latest",
    "yaml": "^2.7.0",
    "commander": "^12.1.0",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "license": "MIT"
}
