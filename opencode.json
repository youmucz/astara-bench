{
  "$schema": "https://opencode.ai/config.json",
  "model": "minimax-cn-coding-plan/MiniMax-M2.7-highspeed",
  "plugin": [
    "opencode-vibeguard",
    "@franlol/opencode-md-table-formatter@latest",
    "@spoons-and-mirrors/subtask2@latest"
  ],
  "share":"disabled",
  "autoupdate":false,
  "experimental": {
    "openTelemetry":false
  },
  "permission": {
    "bash": {
      "*": "allow",
      "git *": "allow",
      "npm *": "allow",
      "rm *": "allow",
      "grep *": "allow"
    },
    "edit": {
      "*": "allow"
    }
  }
}